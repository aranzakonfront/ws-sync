# ============================================================
# WS SYNC - Variables de entorno
# Copia este archivo como .env para desarrollo local
# En Railway, configura estas variables en el panel de Variables
# ============================================================

# --- SAPPO (PostgreSQL externo, solo lectura) ---
SAPPO_HOST=
SAPPO_PORT=5432
SAPPO_DB=
SAPPO_USER=
SAPPO_PASSWORD=

# --- Supabase ---
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_SERVICE_KEY=          # Service Role Key (no la anon key)

# --- Web Service (WS) origen - Banner / Academic Partnership ---
# Base de datos: prefijo de endpoints (lowercase): applicant, billing, enrollment, section, student
WS_BASE_URL=https://prd-apwn-int01.ban.anahuac.mx/wsAcademicPartnership/api
WS_TOKEN_URL=https://prd-apwn-int01.ban.anahuac.mx/wsAcademicPartnership/token

# Basic Auth para generar el token (se regenera antes de cada llamada de datos)
WS_AUTH_USERNAME=AcademicPartnership_AOL
WS_AUTH_PASSWORD=

WS_TIMEOUT_SEGUNDOS=300        # 5 min por llamada
WS_MAX_REINTENTOS=3
WS_BACKOFF_SEGUNDOS=10         # espera entre reintentos

# --- Bubble (para SC de Applicant) ---
BUBBLE_API_URL=https://comunidad.anahuaconline.com/api/1.1/wf/sociocomercial
BUBBLE_API_KEY=

# --- Alertas (opcional) ---
# Configura para recibir email si el job falla
ALERT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
